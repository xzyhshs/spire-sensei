{
  "appId": "com.spiresensei.app",
  "productName": "Spire Sensei",
  "directories": {
    "output": "release"
  },
  "win": {
    "target": "nsis",
    "icon": "resources/icon.ico",
    "signAndEditExecutable": false,
    "verifyUpdateCodeSignature": false
  },
  "nsis": {
    "oneClick": false,
    "allowToChangeInstallationDirectory": true
  },
  "files": [
    "dist/**/*",
    "dist-electron/**/*",
    "data/**/*",
    "resources/**/*"
  ],
  "npmRebuild": false,
  "nodeGypRebuild": false
}
